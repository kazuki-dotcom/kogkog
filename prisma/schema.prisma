// Dead Man's Switch – Prisma Schema
// Tech stack: Next.js (App Router), Tailwind CSS, Supabase (PostgreSQL), Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── NextAuth v5 required tables ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core domain models ────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  EMPLOYEE
}

enum EmployeeStatus {
  PENDING    // invited, code not yet used
  ACTIVE     // activated and set up
  DECEASED   // trigger has been fired
  REVOKED    // admin manually revoked access
}

model Company {
  id        String     @id @default(cuid())
  name      String
  domain    String?    @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  admins    User[]     @relation("CompanyAdmins")
  employees Employee[]
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(EMPLOYEE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Only set when role == ADMIN
  adminCompanyId String?
  adminCompany   Company? @relation("CompanyAdmins", fields: [adminCompanyId], references: [id])

  // Only set when role == EMPLOYEE
  employee Employee?

  accounts Account[]
  sessions Session[]
}

model Employee {
  id        String         @id @default(cuid())
  userId    String         @unique
  companyId String
  status    EmployeeStatus @default(PENDING)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  // Personal info
  department String?
  jobTitle   String?
  phone      String?

  // Trigger metadata
  triggeredAt    DateTime?
  triggeredById  String?   // admin userId who pressed the button

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  company           Company            @relation(fields: [companyId], references: [id])
  activationTokens  ActivationToken[]
  blacklistKeywords BlacklistKeyword[]
  assetInfo         AssetInfo?
  equipment         Equipment[]
  oauthConnections  OAuthConnection[]
  nextOfKin         NextOfKin?
}

// One-time use tokens issued by admins to invite employees
model ActivationToken {
  id         String    @id @default(cuid())
  token      String    @unique
  employeeId String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ─── Employee-side data ───────────────────────────────────────────────────────

// Keywords the employee wants purged from Gmail/SNS on trigger
model BlacklistKeyword {
  id         String   @id @default(cuid())
  employeeId String
  keyword    String
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, keyword])
}

// Bank accounts, insurance, etc. – shown to next-of-kin only
model AssetInfo {
  id         String   @id @default(cuid())
  employeeId String   @unique
  // Stored encrypted; decrypted only when PDF is generated post-trigger
  dataJson   String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// Next-of-kin contact for step-email delivery
model NextOfKin {
  id         String   @id @default(cuid())
  employeeId String   @unique
  name       String
  email      String
  phone      String?
  relation   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// OAuth tokens for Google, etc.
model OAuthConnection {
  id            String    @id @default(cuid())
  employeeId    String
  provider      String    // "google" | "line"
  accessToken   String    @db.Text
  refreshToken  String?   @db.Text
  scope         String?
  expiresAt     DateTime?
  revokedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, provider])
}

// Equipment loaned by the company to the employee
model Equipment {
  id          String   @id @default(cuid())
  employeeId  String
  name        String
  assetTag    String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}
